{
  "name": "@postly/database",
  "version": "1.0.0",
  "private": true,
  "type": "commonjs",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "eslint src",
    "migrate:generate": "drizzle-kit generate",
    "migrate:push": "drizzle-kit push",
    "migrate:up": "drizzle-kit migrate",
    "studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@postly/config": "*",
    "@postly/shared-types": "*",
    "drizzle-orm": "^0.45.2",
    "langchain": "0.3.37",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "resend": "6.1.3"
  },
  "devDependencies": {
    "@postly/eslint-config": "*",
    "@postly/typescript-config": "*",
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.18.1",
    "eslint": "10",
    "typescript": "^6.0.3"
  }
}
